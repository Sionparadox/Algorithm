def rotate(arr):
    return [list(row) for row in zip(*arr[::-1]) ]

TC = int(input())
for tc in range(1, TC+1):
    N = int(input())
    matrix = [list(map(int, input().split())) for _ in range(N)]
    answer = [['']*3 for _ in range(N)]
    for i in range(3):
        matrix = rotate(matrix)
        for r in range(N):
            answer[r][i] = ''.join(map(str, matrix[r]))
    
    print(f'#{tc}')
    for row in answer:
        print(*row)